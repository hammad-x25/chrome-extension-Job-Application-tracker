{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "1.0.0",
  "description": "Save and track job applications from any website.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "scripts/background.js"
  },

  "action": {
    "default_title": "Open Job Tracker"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}